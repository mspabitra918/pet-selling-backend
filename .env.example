# Copy to .env for local dev. On Vercel, set these in
# Project Settings → Environment Variables (do NOT commit real secrets).

# Application
PORT=4000
NODE_ENV=production

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=https://your-frontend.vercel.app

# PostgreSQL database (use a cloud Postgres host, e.g. Supabase/Neon/RDS)
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_DIALECT=postgres
DB_LOGGING=false
# Cloud Postgres requires SSL — set to true in production
DB_SSL=true

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Supabase Storage (pet photo uploads) — use the SERVICE ROLE key (secret)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=
MAILGUN_API_URL=
